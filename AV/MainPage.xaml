<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AV.MainPage">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Label Text="Temperatura (°C ou °F)" />

        <Entry x:Name="EntradaTemp"
               Placeholder="Digite a temperatura"
               Keyboard="Numeric" />

        <Slider x:Name="SliderTemp"
                Minimum="-50"
                Maximum="150"
                MinimumTrackColor="SteelBlue"
                MaximumTrackColor="DarkRed"
                ValueChanged="SliderTemp_ValueChanged"
                WidthRequest="200"/>

        <Image x:Name="ImagemClima"
               HeightRequest="120"
               HorizontalOptions="Center" />

        <HorizontalStackLayout Spacing="10">

            <Button Text="C → F"
                    Clicked="ConverterParaFahrenheit" />

            <Button Text="F → C"
                    Clicked="ConverterParaCelsius" />

        </HorizontalStackLayout>

        <Label Text="Resultado" />

        <Entry x:Name="TemperaturaConvertida"
               Placeholder="Resultado"
               IsReadOnly="True" />

    </VerticalStackLayout>

</ContentPage>