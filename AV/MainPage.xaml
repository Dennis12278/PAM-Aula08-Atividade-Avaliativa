<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AV.MainPage">

    <VerticalStackLayout Padding="20" Spacing="15">


        <Entry x:Name="TemperaturaInicialEntry"
               Placeholder="0"
               SemanticProperties.Description="Caixa"
               SemanticProperties.HeadingLevel="Level1"/>

        <Slider x:Name="TemperaturaInicialSlider"
                Minimum="-200"
                Maximum="200"
                Value="100"
                ValueChanged="TemperaturaInicialSlider_ValueChanged"/>

        <Image x:Name="ClimaImagem"    
               HeightRequest="100"
               WidthRequest="100"
               HorizontalOptions="Center"/>

        <Label
            x:Name="TemperaturaConvertidaLabel"
            Text="0º"
            FontSize="Header"/>

        <HorizontalStackLayout
            HorizontalOptions="Center"
            Spacing="50">

            <Button
                x:Name="ConverterCelsiusButton"
                Text="Cº"
                Clicked="ConverterCelsiusButton_Clicked"
                WidthRequest="120"/>

            <Button
                x:Name="ConverterFahrenheitButton"
                Text="Fº"
                Clicked="ConverterFahrenheitButton_Clicked"
                WidthRequest="120"/>

        </HorizontalStackLayout>

    </VerticalStackLayout>

</ContentPage>