<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AV.SobrePage"
             Title="SobrePage">
    <VerticalStackLayout>
        
        <!-- Imagem normal -->
        <Image Source="flork.jpg"
       WidthRequest="200"
       HeightRequest="200"
       HorizontalOptions="Center"/>

        <Label
            HorizontalOptions="Center"
            Text="Feito Por: Dennis"/>

        <Button
            x:Name="GitHubButton"
            Text="Ir paro o repositório"
            Clicked="GitHubButton_Clicked"
            HorizontalOptions="Center" />
        
    </VerticalStackLayout>
</ContentPage>